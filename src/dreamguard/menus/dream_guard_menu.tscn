; DreamGuard Menu scene.
; Place this scene anywhere in your VR scene (e.g. under XROrigin3D).
; Assign `controller`, `camera`, and `dreamguard` in the Inspector, or leave
; them blank for auto-detection from the scene tree.
;
; INTERACTION:
;   Press menu_button (default B/Y) to toggle the panel open/closed.
;   Aim the laser at a button, then press select_button (default trigger) to select.
;
; COLLISION LAYERS:
;   Buttons use layer 2, RayCast3D mask=2 so the laser ignores gameplay physics.
;   Change BUTTON_LAYER in the script + the layer/mask values below if layer 2
;   conflicts with your project.

[gd_scene format=3 uid="uid://dg_menu_v1"]

[ext_resource type="Script" path="res://addons/dreamguard/menus/dream_guard_menu.gd" id="Script"]

; --- Laser beam (thin box, Z-scaled at runtime) ------------------------------

[sub_resource type="BoxMesh" id="BeamMesh"]
size = Vector3(0.003, 0.003, 1.0)

[sub_resource type="StandardMaterial3D" id="BeamMat"]
shading_mode = 1
albedo_color = Color(0.4, 0.7, 1.0, 1)
emission_enabled = true
emission = Color(0.4, 0.7, 1.0, 1)
emission_energy_multiplier = 1.5

; --- Menu panel --------------------------------------------------------------

[sub_resource type="BoxMesh" id="BgMesh"]
size = Vector3(0.22, 0.26, 0.002)

[sub_resource type="StandardMaterial3D" id="BgMat"]
shading_mode = 1
albedo_color = Color(0.05, 0.05, 0.10, 1)

[sub_resource type="BoxMesh" id="BtnMesh"]
size = Vector3(0.18, 0.028, 0.003)

; BoxShape is slightly deeper than the mesh so the ray hits cleanly.
[sub_resource type="BoxShape3D" id="BtnShape"]
size = Vector3(0.18, 0.028, 0.015)

[sub_resource type="StandardMaterial3D" id="BtnMatDefault"]
shading_mode = 1
albedo_color = Color(0.12, 0.12, 0.20, 1)

; --- Root --------------------------------------------------------------------

[node name="DreamGuardMenu" type="Node3D"]
script = ExtResource("Script")

; LaserPivot global transform is overwritten every frame to match the controller.
; RayCast3D shoots along local -Z (controller aim direction).
; collision_mask=2 targets only the menu buttons (layer 2), ignoring gameplay.
[node name="LaserPivot" type="Node3D" parent="."]

[node name="RayCast3D" type="RayCast3D" parent="LaserPivot"]
target_position = Vector3(0, 0, -5)
collision_mask = 2
collide_with_areas = true
collide_with_bodies = false

; BeamMesh sits centered between origin and target. Scale z and position z
; are updated each frame in the script to match the actual hit distance.
[node name="BeamMesh" type="MeshInstance3D" parent="LaserPivot/RayCast3D"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, -0.5)
mesh = SubResource("BeamMesh")
surface_material_override/0 = SubResource("BeamMat")

; MenuPanel is repositioned globally in _open_menu().
; Its local origin is at the panel centre; -Z faces the camera after look_at().
[node name="MenuPanel" type="Node3D" parent="."]

[node name="Background" type="MeshInstance3D" parent="MenuPanel"]
mesh = SubResource("BgMesh")
surface_material_override/0 = SubResource("BgMat")

[node name="TitleLabel" type="Label3D" parent="MenuPanel"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.108, -0.003)
pixel_size = 0.0005
no_depth_test = true
text = "DreamGuard Mode"
font_size = 36
outline_size = 4

; --- Buttons (Y axis, top = positive) ----------------------------------------
; Layout: 6 buttons × 0.028 m height + 0.007 m gap = 0.035 m per slot
; Centre range: ±0.0875 m  →  slots at 0.070, 0.035, 0.000, -0.035, -0.070, -0.105

[node name="BtnNone" type="Area3D" parent="MenuPanel"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.070, 0)
collision_layer = 2
collision_mask = 0

[node name="CollisionShape3D" type="CollisionShape3D" parent="MenuPanel/BtnNone"]
shape = SubResource("BtnShape")

[node name="ButtonMesh" type="MeshInstance3D" parent="MenuPanel/BtnNone"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, -0.002)
mesh = SubResource("BtnMesh")
surface_material_override/0 = SubResource("BtnMatDefault")

[node name="Label" type="Label3D" parent="MenuPanel/BtnNone"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, -0.006)
pixel_size = 0.0005
no_depth_test = true
text = "None (Control)"
font_size = 26
outline_size = 3

; ----

[node name="BtnGrid" type="Area3D" parent="MenuPanel"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.035, 0)
collision_layer = 2
collision_mask = 0

[node name="CollisionShape3D" type="CollisionShape3D" parent="MenuPanel/BtnGrid"]
shape = SubResource("BtnShape")

[node name="ButtonMesh" type="MeshInstance3D" parent="MenuPanel/BtnGrid"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, -0.002)
